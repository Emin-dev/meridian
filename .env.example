# Copy this file to .env.local and fill in real values for local development.
# On Vercel these are set as Project → Settings → Environment Variables.

# Neon Postgres connection string (Vercel → Storage → Neon auto-provides this).
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Secret for signing sessions/tokens. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-random-secret"
